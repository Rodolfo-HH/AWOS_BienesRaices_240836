extends ../layout/admin

block styles 
    meta(name="csrf-token" content=csrfToken)

block contenido 
    .py-10
        h1.text-4xl.my-10.font-extrabold.text-center Bienes 
            span.font-normal Raices
        h2.text-center.text-2xl.font-extrabold= pagina

        div.bg-white.shadow.py-8.px-4.rounded.max-w-4xl.mx-auto.my-10.md.px-10
            form#imagen.dropzone.border-dashed.border-2.w-full.min-h-48.rounded.flex.flex-col.justify-center.items-center(
                method="POST"
                action=`/propiedades/agregar-imagen/${propiedad.id}`
            )

            button#publicar.mt-5.bg-blue-600.w-full.text-white.uppercase.font-bold.text-lg.rounded-md.py-3.cursor-pointer.hover.bg-blue-700 Publicar Propiedad

block scripts 
    script(type="module" src="/js/agregarImagen.js")