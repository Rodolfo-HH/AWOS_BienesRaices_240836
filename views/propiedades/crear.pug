extends ../layout/admin

block styles 
    link(rel="stylesheet" href="https://unpkg.com/leaflet@1.8.0/dist/leaflet.css")

block contenido 
    .py-10
        h1.text-4xl.my-10.font-extrabold.text-center Bienes 
            span.font-normal Raices
        h2.text-center.text-2xl.font-extrabold= pagina

        div(class="bg-white shadow py-8 px-4 rounded max-w-4xl mx-auto my-10 md:px-10")
            form.space-y-8(method="POST" action="/propiedades/crear")
                input(type="hidden" name="_csrf" value=csrfToken)
                div.space-y-5
                    h3.text-2xl.font-bold.text-gray-700.text-center Informacion General
                    p.text-gray-600.text-center.text-sm.font-medium Completa el formulario para crear una nueva propiedad

                    div
                        label.block.text-sm.font-bold.text-gray-500(for="titulo") Título de la Propiedad:
                        input#titulo.w-full.px-3.py-2.border.border-gray-300.rounded-md.placeholder-gray-400(placeholder="Título de la propiedad ej. Villa Moderna" type="text" name="titulo" value=datos.titulo ? datos.titulo : '')
                    
                    div 
                        label.block.text-sm.font-bold.text-gray-700(for="descripcion") Descripción de la Propiedad:
                        textarea#descripcion.w-full.px-3.py-2.border.border-gray-300.rounded-md(placeholder="Descripción de la propiedad" name="descripcion" rows="4")= datos.descripcion ? datos.descripcion : ''

                    div(class="md:flex md:gap-4 space-y-5 md:space-y-0")

                        div(class="md:w-1/2")
                            label.block.text-sm.font-bold.text-gray-700(for="categoria") Categoria:
                            select#categoria.w-full.px-3.py-2.border.border-gray-300.rounded-md(name="categoria")
                                option(value="") -- Seleccione --
                                each categoria in categorias
                                    option(value=categoria.id selected=datos.categoria ? datos.categoria == categoria.id  ? true : false : null ) #{categoria.nombre}

                        div(class="md:w-1/2")
                            label.block.text-sm.font-bold.text-gray-700(for="precio") Precio:
                            select#precio.w-full.px-3.py-2.border.border-gray-300.rounded-md(name="precio")
                                option(value="") -- Seleccione --
                                each precio in precios
                                    option(value=precio.id selected=datos.precio ? datos.precio == precio.id ? true : false : null) #{precio.nombre}
                    
                    div(class="md:flex md:gap-4 space-y-5 md:space-y-0")

                        div(class="md:w-1/3")
                            label.block.text-sm.font-bold.text-gray-700(for="habitaciones") Habitaciones:
                            select#habitaciones.w-full.px-3.py-2.border.border-gray-300.rounded-md(name="habitaciones")
                                option(value="") -- Seleccione --
                                - var n = 1;
                                    while n <= 6
                                        option(value=n selected=datos.habitaciones ? datos.habitaciones == n ? true : false : null) #{n++}

                        div(class="md:w-1/3")
                            label.block.text-sm.font-bold.text-gray-700(for="estacionamientos") Estacionamientos:
                            select#estacionamientos.w-full.px-3.py-2.border.border-gray-300.rounded-md(name="estacionamientos")
                                option(value="") -- Seleccione --
                                - var n = 0;
                                    while n <= 4
                                        option(value=n selected=datos.estacionamientos ? datos.estacionamientos == n ? true : false : null) #{n++}

                        div(class="md:w-1/3")
                            label.block.text-sm.font-bold.text-gray-700(for="wc") WC:
                            select#wc.w-full.px-3.py-2.border.border-gray-300.rounded-md(name="wc")
                                option(value="") -- Seleccione --
                                - var n = 1;
                                    while n <= 4
                                        option(value=n selected=datos.wc ? datos.wc == n ? true : false : null) #{n++}
                div.border-gray-200.border-t.py-5.space-y-5
                    h3.text-2xl.font-bold.text-gray-700.text-center Ubicación
                    p.text-gray-600.text-center.text-sm.font-medium Completa la dirección de la propiedad para mostrarla en el mapa                
                    #mapa.h-96.w-full.rounded-md.border.border-gray-300

                    div 
                        p.calle=datos.calle ? datos.calle : '' 

                    input(type="hidden" name="calle" id="calle" value=datos.calle ? datos.calle : '')
                    input(type="hidden" name="lat" id="lat" value=datos.lat ? datos.lat : '')
                    input(type="hidden" name="lng" id="lng" value=datos.lng ? datos.lng : '')

                input(class="bg-blue-600 w-full text-white uppercase font-bold text-lg rounded-md py-3 cursor-pointer hover:bg-blue-700 transition-colors" type="submit" value="Añadir Imagen")
            
block scripts                    
    script(src="https://unpkg.com/leaflet@1.8.0/dist/leaflet.js")
    script(src="https://unpkg.com/esri-leaflet@3.0.8/dist/esri-leaflet.js")
    script(src="https://unpkg.com/esri-leaflet-geocoder@2.2.13/dist/esri-leaflet-geocoder.js")
    script(src="https://cdnjs.cloudflare.com/ajax/libs/leaflet-geosearch/2.7.0/bundle.min.js")
    script(src="/js/mapa.js")