extends ../layout/admin

block contenido 
    .py-10
        h2.text-center.text-2xl.font-light= pagina

        div(class="flex justify-center md:justify-start px-6 md:px-12 my-10")
            a(
                href='/propiedades/crear' 
                class='inline-block bg-green-500 hover:bg-green-700 text-white uppercase font-bold text-sm rounded-xl py-4 px-10 transition-all duration-300 shadow-lg hover:shadow-2xl transform hover:scale-105 tracking-wider'
            ) Crear Propiedad

        if propiedades && propiedades.length

            div(class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 px-6 md:px-12")
                each propiedad in propiedades
                    div(class="bg-white rounded-lg shadow-md overflow-hidden border border-gray-200")
                        
                        div(class="relative w-full h-48")
                            img(
                                src=`/uploads/${propiedad.imagen || 'default.jpg'}`, 
                                alt=`Imagen de la propiedad ${propiedad.titulo}`, 
                                class="w-full h-full object-cover"
                            )
                        
                        div(class="p-4")
                            h3(class="text-lg font-bold text-gray-900 mb-2 truncate")= propiedad.titulo
                            p(class="text-gray-900 text-sm font-medium mb-2")= propiedad.categoria ? propiedad.categoria.nombre : 'Sin categoría'
                            
                            div(class="flex items-center gap-2 mb-4")
                                svg(xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-gray-700")
                                    path(stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z")
                                span(class="text-gray-700 text-sm font-medium")= propiedad.precio ? propiedad.precio.nombre : 'Sin precio'
                                
                            //- Tres botones iguales, todos clickeables
                            div(class="flex gap-2")
                                
                                //- Botón Publicado/No Publicado
                                form(
                                    action=`/propiedades/cambiar-estado/${propiedad.id}`
                                    method="POST"
                                    class="flex-1"
                                )
                                    input(type="hidden" name="_csrf" value=csrfToken)
                                    if propiedad.publicado
                                        button(
                                            type="submit"
                                            class="w-full px-3 py-2 text-xs font-semibold rounded cursor-pointer bg-green-100 text-green-800 border border-green-200 hover:bg-green-200 transition-colors"
                                        ) Publicado
                                    else
                                        button(
                                            type="submit"
                                            class="w-full px-3 py-2 text-xs font-semibold rounded cursor-pointer bg-red-100 text-red-800 border border-red-200 hover:bg-red-200 transition-colors"
                                        ) No Publicado
                                
                                //- Botón Editar
                                form(
                                    action=`/propiedades/editar/${propiedad.id}`
                                    method="GET"
                                    class="flex-1"
                                )
                                    button(
                                        type="submit"
                                        class="w-full px-3 py-2 text-xs font-semibold rounded cursor-pointer bg-blue-100 text-blue-800 border border-blue-200 hover:bg-blue-200 transition-colors"
                                    ) Editar
                                
                                //- Botón Eliminar
                                form(
                                    action=`/propiedades/eliminar/${propiedad.id}`
                                    method="POST"
                                    class="flex-1"
                                )
                                    input(type="hidden" name="_csrf" value=csrfToken)
                                    button(
                                        type="submit"
                                        onclick="return confirm('¿Estás seguro de eliminar esta propiedad?')"
                                        class="w-full px-3 py-2 text-xs font-semibold rounded cursor-pointer bg-red-100 text-red-800 border border-red-200 hover:bg-red-200 transition-colors"
                                    ) Eliminar

        else 
            div(class="flex justify-center items-center py-20")
                p.text-center.text-gray-600.text-lg No hay propiedades para mostrar