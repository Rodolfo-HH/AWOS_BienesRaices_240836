extends ../layout/index

block contenido
    .py-10
        h1.text-4xl.my-10.font-extrabold.text-center 
            | Bienes 
            span.font-normal Raices

        h2.text-center.text-2xl.font-extrabold= pagina

        div(class="max-w-md mx-auto mt-10 bg-white p-6 rounded-lg shadow-md")

            if errores
                each error in errores
                    p(class="bg-red-100 text-red-600 p-2 mb-3 rounded")= error.msg

            form(method="POST")
                input(type="hidden" name="_csrf" value=csrfToken)

                input(
                    type="password"
                    name="password"
                    placeholder="Nueva contraseña"
                    class="w-full border p-3 mb-3 rounded"
                )

                input(
                    type="password"
                    name="repetir_password"
                    placeholder="Repetir contraseña"
                    class="w-full border p-3 mb-3 rounded"
                )

                button(
                    type="submit"
                    class="w-full bg-blue-600 text-white p-3 rounded hover:bg-blue-700"
                ) Guardar contraseña